# CouchDB credentials
COUCHDB_USER=your_admin_user
COUCHDB_PASSWORD=your_secure_password

# Obsidian LiveSync end-to-end encryption passphrase (optional – leave empty to disable encryption)
# This is the passphrase you configured in the LiveSync plugin settings.
# It is NEVER stored in CouchDB — you must provide it here if E2EE is enabled.
E2EE_PASSPHRASE=

# CouchDB database name (default: obsidiannotes)
DB_NAME=obsidiannotes

# CouchDB URL (default: http://127.0.0.1:5984)
# COUCHDB_URL=http://127.0.0.1:5984
